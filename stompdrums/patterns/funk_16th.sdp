# StompDrums Pattern v1
# Funk 16th — syncopated funk groove
name: Funk 16th
timesig: 4/4
resolution: 4
swing: 52
bpm_default: 105

instrument: KK = kick.wav
instrument: SN = snare.wav
instrument: HH = hihat_closed.wav
instrument: HO = hihat_open.wav

# 16 steps — funky syncopation
# Beat:  1 . . . 2 . . . 3 . . . 4 . . .
grid: KK  9..5..9...5.9...
grid: SN  ....9.......9.5.
grid: HH  5.5.5.5.5.5.5...
grid: HO  ..............5.
